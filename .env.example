# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development        # development | staging | production
APP_LOG_LEVEL=INFO         # TRACE | DEBUG | INFO | WARN | ERROR

# ── Harness CI/CD ─────────────────────────────────────────────────────────────
# These are set as Harness secrets — never commit real values here.
HARNESS_ACCOUNT_ID=<your-account-id>
HARNESS_API_KEY=<your-api-key>
HARNESS_ORG_ID=default
HARNESS_PROJECT_ID=HelloWorld
