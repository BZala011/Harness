# Normalise line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.java    text eol=lf
*.xml     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.json    text eol=lf
*.sh      text eol=lf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary files — never diff or merge
*.jar     binary
*.class   binary
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
